# Comma-separated list of Solana RPC endpoints for automatic health load-balancing
RPC_URLS=https://api.mainnet-beta.solana.com,http://invalid-fallback-url.local:8899

# PostgreSQL connection string
DATABASE_URL=postgresql://indexer:indexer@localhost:5432/solana_indexer

# Program to index
PROGRAM_ID=YOUR_PROGRAM_ID_HERE

# IDL source (set at least one)
IDL_PATH=./idl.json
# IDL_ACCOUNT=YOUR_IDL_ACCOUNT_ADDRESS

# Indexing mode: realtime | batch_slots | batch_signatures
INDEXING_MODE=realtime
# BATCH_START_SLOT=250000000
# BATCH_END_SLOT=250001000
# BATCH_SIGNATURES=sig1,sig2,sig3

# API server
API_PORT=3000

# Tuning
BATCH_SIZE=100
MAX_RETRIES=5
RETRY_DELAY_MS=500
POLL_INTERVAL_MS=2000

# Logging
RUST_LOG=solana_indexer_v1=info,sqlx=warn
